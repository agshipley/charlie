ANTHROPIC_API_KEY=your-api-key-here

# Agent model configuration
MODEL_DAILY=claude-sonnet-4-6
MODEL_DEEP=claude-opus-4-6

# Scheduling
BRIEF_HOUR=6
BRIEF_TIMEZONE=America/Los_Angeles

# State storage path (relative to project root)
DATA_DIR=data

# Operator admin token (protects /admin/* operator surfaces)
ADMIN_TOKEN=

# Dead-man's-switch: Charlie GETs this URL after each successful daily brief.
# Point it at a healthchecks.io (or similar) check that alerts you when a ping is
# missed. Leave unset to disable (Charlie logs-and-skips, never crashes).
DEADMAN_PING_URL=
